{
  "version": 2,
  "routes": [
    {
      "src": "/",
      "dest": "/Heph.html"
    },
    {
      "src": "/index",
      "dest": "/Heph.html"
    },
    {
      "src": "/home",
      "dest": "/Heph.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  }
} 